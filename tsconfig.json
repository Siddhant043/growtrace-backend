{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "outDir": "dist",
      "rootDir": ".",
      "types": ["node"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts", "prisma.config.ts"],
    "exclude": ["node_modules", "dist"]
}